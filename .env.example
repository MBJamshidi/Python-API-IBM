# IBM Watson Speech to Text credentials
# Get these from: https://cloud.ibm.com/resources → your Speech to Text instance → Credentials
SPEECH_TO_TEXT_API_KEY=your_speech_to_text_api_key_here
SPEECH_TO_TEXT_URL=https://api.us-south.speech-to-text.watson.cloud.ibm.com

# IBM Watson Language Translator credentials
# Get these from: https://cloud.ibm.com/resources → your Language Translator instance → Credentials
LANGUAGE_TRANSLATOR_API_KEY=your_language_translator_api_key_here
LANGUAGE_TRANSLATOR_URL=https://api.us-south.language-translator.watson.cloud.ibm.com
